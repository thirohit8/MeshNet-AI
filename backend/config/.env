# MeshNet AI — Backend environment variables
# Copy this file to config/.env and fill in values

# Server
PORT=4000

# SQLite database path (relative to project root, or absolute)
DB_PATH=../database/meshnet.db

# Shared secret for node-to-node auth (generate a long random string)
NODE_SECRET=change-me-to-a-long-random-secret

# CORS — restrict to known node origins in production
# CORS_ORIGIN=http://localhost:5173
