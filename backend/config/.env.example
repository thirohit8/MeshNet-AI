# MeshNet AI — Backend environment variables
# Copy this file to config/.env and fill in values

# ── Express server ────────────────────────────────────────────────────────────
PORT=4000

# Node identity (used in /api/health response and log traces)
NODE_ID=cmd-hq

# ── Layer 4: SQLite database ──────────────────────────────────────────────────
# Path is relative to the backend/ directory
DB_PATH=../database/meshnet.db

# ── Layer 3: Python AI routing service ───────────────────────────────────────
# URL of the FastAPI server (api_server.py / uvicorn)
PYTHON_ROUTER_URL=http://localhost:5050

# ── Layer 4: Supabase / PostgreSQL (optional) ────────────────────────────────
# Set these to enable real-time PostgreSQL persistence alongside SQLite.
# Get them from: Supabase → Project Settings → Database → Connection string
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Layer 2: Python simulation tuning (forwarded to config.py) ───────────────
# These must match the values used when building the offline mesh.
# Changing them requires re-seeding the mesh_nodes table.
MESH_RANGE_FLOOD=150
MESH_RANGE_WAR_ZONE=30
MESH_RANGE_EARTHQUAKE=300
MESH_TOTAL_NODES=100

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret for node-to-node API calls — generate a long random string
MESH_SECRET=change-me-to-a-long-random-secret
NODE_SECRET=change-me-to-a-long-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Restrict to known node origins in production
# CORS_ORIGIN=http://localhost:5173
